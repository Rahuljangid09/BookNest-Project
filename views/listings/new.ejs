<%layout("/layouts/boilerplate")%>

<div class="row">
  <div class="col-8 offset-2 mt-4 mb-5 ">
    <h3 class="mb-4">Create New Listing</h3>
    <form action="/listings" method="post" novalidate class="needs-validation" enctype="multipart/form-data">
      <div>
        <label for="title" class="form-label">Enter Title:</label>
        <input
          type="text"
          required
          class="form-control"
          name="listing[title]"
          placeholder="Enter title"
        />
      </div>

      <br />
      <div>
        <label for="description" class="form-label">Enter Description:</label>
        <textarea
          name="listing[description]"
          required
          class="form-control"
          placeholder="enter description"
        ></textarea>
      </div>
      <br />

      <div>
        <label for="image" class="form-label">Upload Image</label>
        <input
          name="listing[image][url]"
          type="file"
          class="form-control"
        />
      </div>

      <br />
      <div class="row">
        <div class="col-md-4">
        <label for="price" class="form-label">Enter Price:</label>
        <input
          
          class="form-control"
          required
          name="listing[price]"
          placeholder="enter price"
        />
      </div>
      <br>
       <div class="col-md-8">
        <label for="country" class="form-label">Enter country:</label>
        <input
          type="text"
          required
          name="listing[country]"
          class="form-control"
          placeholder="enter country"
        />
      </div>
      </div>

      <br />
      <div>
        <label for="location" class="form-label">Enter location:</label>
        <input
          type="text"
          name="listing[location]"
          required
          placeholder="enter location"
          class="form-control"
        />
      </div>
      

     
      <br />
      <button class="btn btn-dark ">Add</button>
    </form>
  </div>
</div>
